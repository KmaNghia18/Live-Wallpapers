{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "src/wallpaper-window/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@wallpaper/*": ["src/wallpaper-window/*"]
    },
    "outDir": "./out/tsconfig.web.tsbuildinfo"
  }
}
